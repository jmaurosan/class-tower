  {
    "id": "TC001",
    "title": "Edit an existing user's role and verify the updated role appears in the list",
    "description": "Verifies an admin can search for a user, edit the role, save, and see the updated role reflected in the user list.",
    "category": "User Management",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on \"Usuários\" in the main navigation menu"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/usuarios\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"User list\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Apto\" into the user search field"
      },
      {
        "type": "action",
        "description": "Click on the first user row in the results list"
      },
      {
        "type": "action",
        "description": "Click on the \"Edit\" button"
      },
      {
        "type": "action",
        "description": "Select \"Admin\" from the role dropdown"
      },
      {
        "type": "action",
        "description": "Click on the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Admin\" is visible"
      }
    ]
  },
