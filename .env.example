# Supabase Configuration
# Este é um arquivo de EXEMPLO. Copie para .env e preencha com suas chaves reais.

# URL do seu projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública (anon key) do Supabase
# SEGURO para usar no frontend - NÃO dá acesso administrativo
# Encontre em: https://supabase.com/dashboard/project/SEU_PROJETO/settings/api
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# ⚠️ NUNCA adicione a SERVICE_ROLE_KEY aqui!
# A SERVICE_ROLE_KEY só deve ser usada no backend/servidor
